{
    "manifest_version": 3,
    "name": "Letterhead",
    "version": "1.0.0",
    "description": "Auto-generates cover letters and outreach messages from job postings",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://*/*",
        "https://api.anthropic.com/*",
        "https://api.openai.com/*"
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_page": "options.html",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "public/letterhead-on-48.png"
        }
    },
    "icons": {
        "48": "public/letterhead-on-48.png"
    }
}